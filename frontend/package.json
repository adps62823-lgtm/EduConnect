{
  "name": "educonnect-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:mobile": "CAPACITOR_BUILD=true vite build",
    "build:mobile:win": "set CAPACITOR_BUILD=true && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "cap:sync": "npm run build:mobile && npx cap sync",
    "cap:android": "npm run build:mobile && npx cap sync android && npx cap open android",
    "cap:ios": "npm run build:mobile && npx cap sync ios && npx cap open ios"
  },
  "dependencies": {
    "@capacitor/browser": "^6.0.0",
    "@capacitor/camera": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@uiw/react-color": "^2.1.1",
    "axios": "^1.7.2",
    "date-fns": "^3.6.0",
    "emoji-picker-react": "^4.9.2",
    "framer-motion": "^11.2.10",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1",
    "react-intersection-observer": "^9.10.3",
    "react-router-dom": "^6.23.1",
    "react-textarea-autosize": "^8.5.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "typescript": "^6.0.3",
    "vite": "^5.2.13"
  }
}
