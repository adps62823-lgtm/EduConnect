# Copy this file to .env and fill in your values

# ── Security ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=4D9347478843383C0C29AB7188BA7A66FA37B0051CAD8A8C4F5089BF6472D28D

# JWT token expiry in minutes (default: 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Database ──────────────────────────────────────────────
# SQLite (default, zero-config for local dev)
DATABASE_URL=sqlite:///./educonnect.db

# ── CORS / Frontend ───────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── File Uploads ──────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# ── App Config ────────────────────────────────────────────
APP_NAME=EduConnect
APP_VERSION=1.0.0
DEBUG=true

# ── School / Pilot Config ─────────────────────────────────
# Set to true to restrict registration to a specific school email domain
RESTRICT_TO_SCHOOL=false
ALLOWED_EMAIL_DOMAIN=sunbeamschools.com
